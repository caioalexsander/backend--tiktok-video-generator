generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Roteiro {
  id                 String        @id @default(cuid())
  titulo             String
  texto              String
  status             RoteiroStatus @default(PENDENTE)
  usado              Boolean       @default(false)
  video_url          String?
  erro               String?
  data_criacao       DateTime      @default(now())
  data_processamento DateTime?

  videos Video[]
  logs   Log[]
}

model Video {
  id               String   @id @default(cuid())
  roteiro_id       String
  google_drive_url String
  duracao          Float
  resolucao        String
  fps              Int
  data_criacao     DateTime @default(now())

  roteiro Roteiro @relation(fields: [roteiro_id], references: [id])
}

model Log {
  id       String   @id @default(cuid())
  processo String
  mensagem String
  nivel    LogNivel
  data     DateTime @default(now())

  roteiro_id String?
  roteiro    Roteiro? @relation(fields: [roteiro_id], references: [id])
}

model Configuracao {
  id                  String  @id @default("global")
  google_drive_folder String?
  speech_provider     String  @default("clipchamp")
  voz_padrao          String  @default("pt-BR")
  velocidade_fala     Float   @default(1.0)
  qtd_imagens         Int     @default(30)
  tempo_por_imagem    Int     @default(2)
  fps                 Int     @default(30)
  resolucao           String  @default("1080x1920")
  ken_burns           Boolean @default(true)
  transicoes          Boolean @default(true)
  max_concorrencia    Int     @default(3)
}

enum RoteiroStatus {
  PENDENTE
  PROCESSANDO
  CONCLUIDO
  ERRO
}

enum LogNivel {
  INFO
  WARN
  ERROR
}
